<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Permanent redirect from index.html to root /
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/index\.html\s [NC]
  RewriteRule ^index\.html$ / [R=301,L]

  # 2. Permanent redirect from other page.html to /page
  RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/([^/]+)\.html\s [NC]
  RewriteRule ^([^/]+)\.html$ /$1 [R=301,L]

  # 3. Silently route extensionless request to page.html if it exists
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([^/]+)$ $1.html [L]
</IfModule>
